# Supabase Configuration
# Get these from your Supabase project dashboard: https://app.supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key-here

# AI Provider Configuration (Google Gemini)
# Get your API key from: https://aistudio.google.com/app/apikey
VITE_GOOGLE_API_KEY=your-google-api-key-here
VITE_AI_MODEL=gemini-1.5-flash

# Optional / Future Use
VITE_APP_NAME=SmartTask AI
VITE_APP_VERSION=0.1.0
# VITE_ENABLE_AI_FEATURES=true
